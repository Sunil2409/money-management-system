# ── Money Manager Environment Configuration ──────────────────────────────────
# Copy this file to .env and configure for your environment.
# Development: use defaults or set DEBUG=True
# Production: set DEBUG=False and configure ALLOWED_HOSTS, SECRET_KEY, and CORS_ALLOWED_ORIGINS

# ── Security (CRITICAL for production) ────────────────────────────────────────
# SECRET_KEY: Django secret key for cryptographic signing
# ⚠️  PRODUCTION: Generate a strong random key using:
#     python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#     DO NOT commit the actual key to version control!
SECRET_KEY=django-insecure-h(&^1_u#*i*e+9zhxtu696z0l%n-+(a*(fv68_zbs(p$gkaylk

# ── Debug Mode ─────────────────────────────────────────────────────────────────
# DEBUG: Set to False in production to disable detailed error pages
# Development: True (default)
# Production: False (required)
DEBUG=True

# ── Allowed Hosts ──────────────────────────────────────────────────────────────
# ALLOWED_HOSTS: Comma-separated list of domains that can access this Django app
# Development: localhost,127.0.0.1 (default)
# Production: yourapp.com,www.yourapp.com,api.yourapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS (Cross-Origin Resource Sharing) ───────────────────────────────────────
# CORS_ALLOWED_ORIGINS: Comma-separated list of frontend origins that can call this API
# Development: http://localhost:5500,http://127.0.0.1:5500 (default)
# Production: https://yourapp.com,https://www.yourapp.com
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# CORS_ALLOW_ALL_ORIGINS: Set to True to allow requests from any origin
# ⚠️  DANGEROUS: Never set to True in production!
# Development: False (recommended, set to True only if necessary)
# Production: False (required)
CORS_ALLOW_ALL_ORIGINS=False

# ── Database (optional, SQLite used by default) ────────────────────────────────
# For production, consider PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/money_manager
# (requires psycopg2 package)

# ── JWT Token Settings (optional) ──────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME: Hours until access token expires (default: 24 hours)
# REFRESH_TOKEN_LIFETIME: Days until refresh token expires (default: 7 days)
# ROTATE_REFRESH_TOKENS: Enable automatic refresh token rotation (default: True)
# ACCESS_TOKEN_LIFETIME=24
# REFRESH_TOKEN_LIFETIME=7
# ROTATE_REFRESH_TOKENS=True
