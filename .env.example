# ============================================================
# Environment Configuration Template — Money Manager
# ============================================================
# Copy this file to .env and update the values for your environment.
# Development: Use default insecure values (provided)
# Production: Generate secure values and set SECURE_* flags to True
# ============================================================

# ── DJANGO CORE ────────────────────────────────────────────
# Django debug mode (NEVER True in production)
DEBUG=False

# Secret key for Django (MUST be changed in production)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-me-in-production

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,example.com,www.example.com

# ── DATABASE ───────────────────────────────────────────────
# SQLite (development) or PostgreSQL (production)
# Set to 'django.db.backends.sqlite3' for SQLite, 'django.db.backends.postgresql' for PostgreSQL
DB_ENGINE=django.db.backends.postgresql

# PostgreSQL connection details (if using PostgreSQL)
DB_NAME=money_manager
DB_USER=mm_user
DB_PASSWORD=secure-password-here
DB_HOST=db
DB_PORT=5432

# ── REDIS CACHE ────────────────────────────────────────────
# Redis URL for caching (empty = in-memory cache)
REDIS_URL=redis://redis:6379/0

# ── CORS & FRONTEND ────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: http://localhost:3000,https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:80,http://127.0.0.1:80

# Allow requests from any origin (ONLY for development, NEVER production)
CORS_ALLOW_ALL_ORIGINS=False

# ── HTTPONLY COOKIE SECURITY ──────────────────────────────
# Enable secure cookie flags (requires HTTPS in production)
# Set to True only with HTTPS enabled
SECURE_COOKIE_ENABLED=False

# ── PRODUCTION SECURITY SETTINGS ──────────────────────────
# Redirect all HTTP to HTTPS (requires SSL certificate)
SECURE_SSL_REDIRECT=False

# Only send cookies over HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HTTP Strict Transport Security (forces HTTPS, max-age in seconds)
# 31536000 = 1 year (only set to non-zero in production with HTTPS)
SECURE_HSTS_SECONDS=0

# Include subdomains in HSTS header
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# ── LOGGING ────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
